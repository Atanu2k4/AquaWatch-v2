# Copy to backend/.env and fill in real values. Never commit the real .env.

# MongoDB (Data Warehouse)
MONGO_URI=
MONGO_DB_NAME=aquawatch
MONGO_COLLECTION_NAME=states

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./aquawatch-firebase-adminsdk.json

# Groq vision (incident report AI analysis)
GROQ_API_KEY=

# Self-issued secret gating this backend's own routes (/today-data, /sync, ...).
# Not a real DWLR/CGWB credential — the DWLR dataset is the static CSV at
# backend/data/sensor_data.csv, there is no external API to authenticate to.
# Any string works for local dev, e.g. `openssl rand -hex 16`.
API_KEY=dev-local-key

# Admin credentials, one JSON object keyed by adminId (format "<STATE>@2026"
# per phase1.2.md section 5.3), 28 entries for the 28 states.
ADMIN_CREDENTIALS={"WB@2026":"change-me","MH@2026":"change-me"}

# Super Admin (single credential pair)
SUPER_ADMIN_ID=
SUPER_ADMIN_PASSWORD=
